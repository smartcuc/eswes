##############################
# forecast/services_weather.py
##############################

import requests
from collections import defaultdict
from django.conf import settings
from django.utils import timezone
from datetime import timezone as dt_timezone

from forecast.models import TenantWeatherSnapshot

DEFAULT_LAT = getattr(settings, "DEFAULT_WEATHER_LAT", 50.9)
DEFAULT_LON = getattr(settings, "DEFAULT_WEATHER_LON", 6.97)


def resolve_forecast_coordinates(tenant):
    """
    Liefert Forecast-Koordinaten für einen Tenant zurück.

    Priorität:
    1. tenant.latitude / tenant.longitude
    2. Default-Koordinaten aus settings
    """
    lat = getattr(tenant, "latitude", None)
    lon = getattr(tenant, "longitude", None)

    if lat is None or lon is None:
        lat = DEFAULT_LAT
        lon = DEFAULT_LON

    return float(lat), float(lon)


def get_location_group_key(tenant):
    """
    Gruppiert Tenants nach Standort.
    Da das Tenant-Modell aktuell lat/lon hat, nutzen wir diese als Schlüssel.

    round(..., 2) = bewusst grob genug, damit identische/nahe Standorte
    nur einen Weather-Call verursachen.
    """
    lat, lon = resolve_forecast_coordinates(tenant)
    return (round(lat, 2), round(lon, 2))


def get_weather_forecast(lat, lon, hours=48):
    """
    Holt stündliche Wetterdaten von Open-Meteo.

    Rückgabeformat:
    {
        "timestamps": [...],
        "radiation": [...],
        "temperature": [...],
        "cloud_cover": [...],
    }
    """
    url = "https://api.open-meteo.com/v1/forecast"

    params = {
        "latitude": lat,
        "longitude": lon,
        "hourly": "shortwave_radiation,cloud_cover,temperature_2m",
        "forecast_days": 3,
        "timezone": "UTC",
    }

    response = requests.get(url, params=params, timeout=15)
    response.raise_for_status()

    data = response.json()
    hourly = data["hourly"]

    return {
        "timestamps": hourly.get("time", [])[:hours],
        "radiation": hourly.get("shortwave_radiation", [])[:hours],
        "temperature": hourly.get("temperature_2m", [])[:hours],
        "cloud_cover": hourly.get("cloud_cover", [])[:hours],
    }


def store_weather_payload_for_tenant(tenant, payload):
    """
    Speichert einen bereits geladenen Weather-Payload für genau einen Tenant.
    """
    written = 0

    for ts, rad, temp, clouds in zip(
        payload["timestamps"],
        payload["radiation"],
        payload["temperature"],
        payload["cloud_cover"],
    ):
        dt = timezone.datetime.fromisoformat(ts)

        if timezone.is_naive(dt):
            dt = timezone.make_aware(dt, dt_timezone.utc)

        TenantWeatherSnapshot.objects.update_or_create(
            tenant=tenant,
            ts=dt,
            defaults={
                "temperature_c": temp,
                "cloud_cover_pct": clouds,
                "shortwave_radiation_wm2": rad,
            },
        )
        written += 1

    return written


def fetch_and_store_weather_for_group(tenants, hours=48):
    """
    Holt Wetter EINMAL für eine Tenant-Gruppe mit gleicher Location
    und speichert es für jeden Tenant der Gruppe.

    Erwartet:
    - tenants = Liste/Iterable von Tenant-Objekten
    """
    tenants = list(tenants)
    if not tenants:
        return {
            "status": "ok",
            "count": 0,
            "tenant_count": 0,
        }

    lat, lon = resolve_forecast_coordinates(tenants[0])
    payload = get_weather_forecast(lat, lon, hours=hours)

    total_written = 0

    for tenant in tenants:
        total_written += store_weather_payload_for_tenant(tenant, payload)

    return {
        "status": "ok",
        "count": len(payload["timestamps"]),
        "tenant_count": len(tenants),
        "lat": lat,
        "lon": lon,
        "written_total": total_written,
    }


def group_tenants_by_location(tenants):
    """
    Gruppiert Tenants nach Standort.
    """
    groups = defaultdict(list)

    for tenant in tenants:
        key = get_location_group_key(tenant)
        groups[key].append(tenant)

    return groups
